# Servidor
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/bildyapp2?retryWrites=true&w=majority

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES=7d

# Uploads
MAX_LOGO_SIZE_MB=5

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cloudinary (opcional; si se deja vacío, se usa almacenamiento local en /uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# SMTP para envío de emails (opcional; si se deja vacío, se hace fallback a console.log)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BildyApp <no-reply@bildyapp.test>

# Slack Incoming Webhook para notificación de errores 5XX (opcional)
SLACK_WEBHOOK_URL=
